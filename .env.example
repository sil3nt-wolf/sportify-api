# ─── Server ───────────────────────────────────────────────
PORT=3001

# ─── Token Refresh Interval ───────────────────────────────
# How often to refresh the Spotify token (minutes)
REFRESH_INTERVAL_MINUTES=30

# ─── GitHub (optional — for remote token commits) ─────────
# If not set, tokens are still saved locally to tokens.json
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=your-username/your-tokens-repo
GITHUB_FILE_PATH=tokens.json
