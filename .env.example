# Port the API will run on
PORT=3001

# GitHub repo to push tokens to (format: username/repo-name)
GITHUB_REPO=your-username/spotify-tokens

# GitHub Personal Access Token (needs repo write access)
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token

# File path inside the GitHub repo to write tokens to
GITHUB_FILE_PATH=tokens.json

# How often to refresh the token in minutes (default: 30)
REFRESH_INTERVAL_MINUTES=30
